generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// MODELS
// ============================================================================

/// User in the system
model User {
  /// Unique user identifier
  id String @id @default(cuid())

  /// User's email address (unique)
  email String @unique

  /// User's display name
  name String?

  /// Password hash (implement proper hashing in application)
  passwordHash String?

  /// Refresh token for JWT authentication
  refreshToken String?

  /// Whether the user account is active
  isActive Boolean @default(true)

  /// Last login timestamp
  lastLoginAt DateTime?

  /// User creation timestamp
  createdAt DateTime @default(now())

  /// Last update timestamp
  updatedAt DateTime @updatedAt

  /// Budget sections owned by this user
  sections Section[]

  /// Debts owned by this user
  debts Debt[]

  @@map("users")
}

/// Represents a budget section (e.g., "movements", "physical expenses", "digital expenses")
model Section {
  /// Unique section identifier
  id String @id @default(cuid())

  /// Section title
  title String

  /// Section icon identifier
  icon String

  /// Section type (simple_list or summary_list)
  type SectionType @default(SIMPLE_LIST)

  /// Whether this section contributes to income (true) or expenses (false)
  isIncome Boolean @default(false)

  /// Total amount in this section (used for summary_list)
  total Float @default(0)

  /// Action label shown on the section (e.g. "Agregar")
  actionLabel String?

  /// Display order
  order Int

  /// Owner of this section
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Section creation timestamp
  createdAt DateTime @default(now())

  /// Last update timestamp
  updatedAt DateTime @updatedAt

  /// Associated items in this section
  items SectionItem[]

  @@map("sections")
}

/// Individual item within a section
model SectionItem {
  /// Unique item identifier
  id String @id @default(cuid())

  /// Item name/description
  name String

  /// Item amount
  amount Float

  /// Visual variant for display (income, expense, neutral, default)
  variant String?

  /// Whether this item has been paid
  isPaid Boolean @default(false)

  /// Related section
  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  /// Item creation timestamp
  createdAt DateTime @default(now())

  /// Last update timestamp
  updatedAt DateTime @updatedAt

  @@map("section_items")
}

/// Credit card or debt tracking
model Debt {
  /// Unique debt identifier
  id String @id @default(cuid())

  /// Card/debt display name
  name String

  /// Subtitle shown on the card (e.g. "Saldo pendiente")
  subtitle String

  /// Total amount used/owed (sum of details)
  amount Float @default(0)

  /// Debt type (e.g. credit_card)
  type String @default("credit_card")

  /// Visual color hint (purple, blue)
  color String @default("blue")

  /// Display order
  order Int

  /// Owner of this debt
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Debt creation timestamp
  createdAt DateTime @default(now())

  /// Last update timestamp
  updatedAt DateTime @updatedAt

  /// Individual purchase/charge details
  details DebtDetail[]

  @@map("debts")
}

/// Individual charge or purchase within a debt card
model DebtDetail {
  /// Unique detail identifier
  id String @id @default(cuid())

  /// Description of the charge
  name String

  /// Amount of the charge
  amount Float

  /// Parent debt
  debtId String
  debt   Debt   @relation(fields: [debtId], references: [id], onDelete: Cascade)

  /// Detail creation timestamp
  createdAt DateTime @default(now())

  /// Last update timestamp
  updatedAt DateTime @updatedAt

  @@map("debt_details")
}



// ============================================================================
// ENUMS and TYPES
// ============================================================================

/// Section type enum for categorizing budget sections
enum SectionType {
  SIMPLE_LIST
  SUMMARY_LIST

  @@map("section_type_enum")
}
